{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git commit -m \"auto: update\" && git push",
            "shell": "powershell",
            "statusMessage": "Качвам промените в GitHub...",
            "async": true
          }
        ]
      }
    ]
  }
}
